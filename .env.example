# VENOM Configuration Example
# Copy to .env and fill in your values
# DO NOT COMMIT .env file to git

# API Configuration
VENOM_API_HOST=127.0.0.1
VENOM_API_PORT=9000
VENOM_API_KEY=your_api_key_here
VENOM_API_SECRET=your_api_secret_here

# Proxy Configuration
VENOM_PROXY_HOST=127.0.0.1
VENOM_PROXY_PORT=8080
VENOM_MITM_CA_PATH=.venom/ca.crt
VENOM_MITM_KEY_PATH=.venom/ca.key

# Database
VENOM_DB_PATH=.venom/history.db
VENOM_DB_POOL_SIZE=10

# Scanning
VENOM_CONCURRENT_WORKERS=8
VENOM_SCAN_TIMEOUT_SECS=300
VENOM_RATE_LIMIT_RPS=50

# Logging
VENOM_LOG_LEVEL=info
VENOM_LOG_FILE=.venom/venom.log

# Compliance
VENOM_COMPLIANCE_FRAMEWORK=gdpr
VENOM_AUDIT_LOG_ENABLED=true

# Threat Intelligence
VENOM_THREAT_FEED_CACHE_TTL=3600
VENOM_CVE_AUTO_UPDATE=true

# Features
VENOM_LUA_SCRIPTS_ENABLED=true
VENOM_EVENT_BUS_ENABLED=true
VENOM_DISTRIBUTED_MODE=false

# Development
VENOM_DEBUG=false
VENOM_PROFILE_PERFORMANCE=false
